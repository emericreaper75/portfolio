rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Entity Validations
    function isValidProject(data) {
      return data.title is string && data.title.size() <= 200 &&
             data.description is string && data.description.size() <= 1000 &&
             data.image is string && data.image.size() <= 1000 &&
             data.tags is list && data.tags.size() <= 20 &&
             data.slug is string && data.slug.matches('^[a-z0-9-]+$') &&
             data.createdAt is number;
    }

    function isValidBlogPost(data) {
      return data.title is string && data.title.size() <= 200 &&
             data.content is string && data.content.size() <= 100000 &&
             data.excerpt is string && data.excerpt.size() <= 500 &&
             data.author is string &&
             data.tags is list &&
             data.slug is string && data.slug.matches('^[a-z0-9-]+$') &&
             data.createdAt is number;
    }

    function isValidMessage(data) {
      return data.name is string && data.name.size() <= 100 &&
             data.email is string && data.email.size() <= 100 &&
             data.subject is string && data.subject.size() <= 200 &&
             data.message is string && data.message.size() <= 5000 &&
             data.createdAt == request.time;
    }

    // Collections
    match /projects/{projectId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(projectId) && isValidProject(incoming());
      allow update: if isAdmin() && isValidProject(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'longDescription', 'image', 'tags', 'link', 'github', 'featured', 'slug'])
      );
      allow delete: if isAdmin();
    }

    match /blogPosts/{postId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(postId) && isValidBlogPost(incoming());
      allow update: if isAdmin() && isValidBlogPost(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['title', 'content', 'excerpt', 'tags', 'slug', 'featured', 'published'])
      );
      allow delete: if isAdmin();
    }

    match /messages/{messageId} {
      allow create: if isValidId(messageId) && isValidMessage(incoming());
      allow list, get, delete: if isAdmin();
    }

    match /admins/{adminId} {
      allow read: if isSignedIn() && request.auth.uid == adminId;
      // No client allowed to write to admins collection
    }
  }
}
