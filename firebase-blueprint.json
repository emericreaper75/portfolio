{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "An engineering project showcase",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "longDescription": { "type": "string" },
        "image": { "type": "string" },
        "tags": { "type": "array" },
        "link": { "type": "string" },
        "github": { "type": "string" },
        "featured": { "type": "boolean" },
        "slug": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["title", "description", "image", "tags", "slug", "createdAt"]
    },
    "BlogPost": {
      "title": "Blog Post",
      "description": "A technical research entry",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "excerpt": { "type": "string" },
        "author": { "type": "string" },
        "tags": { "type": "array" },
        "slug": { "type": "string" },
        "featured": { "type": "boolean" },
        "published": { "type": "boolean" },
        "createdAt": { "type": "number" }
      },
      "required": ["title", "content", "excerpt", "author", "tags", "slug", "createdAt"]
    },
    "Message": {
      "title": "Contact Message",
      "description": "User submitted contact form",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "number" }
      },
      "required": ["name", "email", "subject", "message", "createdAt"]
    },
    "Admin": {
       "title": "Admin",
       "description": "Whitelisted administrator",
       "type": "object",
       "properties": {
          "email": { "type": "string" }
       }
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Public project showcase"
    },
    "/blogPosts/{postId}": {
      "schema": "BlogPost",
      "description": "Technical blog entries"
    },
    "/messages/{messageId}": {
      "schema": "Message",
      "description": "Contact form submissions"
    },
    "/admins/{adminId}": {
       "schema": "Admin",
       "description": "Whitelisted admin users"
    }
  }
}
